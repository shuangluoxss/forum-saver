{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "forum-saver-tauri",
  "version": "0.2.0",
  "identifier": "com.xss.forum-saver",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:8080",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "forum-saver",
        "width": 880,
        "height": 660
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU2MTAzMEU4NjZDRUU5REYKUldUZjZjNW02REFRVmhmVjF4UzUrcmV0UmE0RENMK05scm9tb240R3VLS3o0M3Rpb2tCMndabDAK",
      "endpoints": [
        "https://github.com/shuangluoxss/forum-saver/releases/latest/download/latest.json"
      ]
    }
  }
}
